                    "min": 12,
                    "max": 24,
                    "step": 2,
                    "value": 16,
                    "defaultParameter": 16
                },
                {
                    "id": "iconOpacity",
                    "name": "Прозрачность иконки",
                    "description": "Прозрачность иконки в неактивном состоянии (5-100%)",
                    "type": "slider",
                    "min": 5,
                    "max": 100,
                    "step": 5,
                    "value": 70,
                    "defaultParameter": 70
                }
            ]
        },
        {
            "title": "Дополнительно",
            "items": [
                {
                    "id": "customFormat",
                    "name": "Пользовательский формат",
