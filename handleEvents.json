                    "buttons": [
                        {
                            "id": "customFormatText",
                            "name": "Формат",
                            "text": "{artist} - {title}",
                            "defaultParameter": "{artist} - {title}"
                        }
                    ]
                },
                {
                    "id": "enableCustomFormat",
                    "name": "Использовать пользовательский формат",
                    "description": "Включить использование пользовательского формата вместо стандартных",
