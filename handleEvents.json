                            "event": "artistDashTitle",
                            "name": "Исполнитель - Название"
                        },
                        "2": {
                            "event": "titleDashArtist",
                            "name": "Название - Исполнитель"
                        },
                        "3": {
                            "event": "artistOnly",
                            "name": "Только исполнитель"
                        },
                        "4": {
                            "event": "titleOnly",
                            "name": "Только название"
                        }
                    },
                    "defaultParameter": 1
                },
                {
                    "id": "showNotification",
                    "name": "Показывать уведомления",
                    "description": "Отображать уведомление при успешном копировании",
                    "type": "button",
                    "bool": true,
                    "defaultParameter": true
                }
            ]
        },
        {
            "title": "Внешний вид",
            "items": [
                {
                    "id": "iconColor",
                    "name": "Статический цвет",
                    "description": "Использовать статический цвет вместо динамического",
                    "type": "button",
                    "bool": false,
                    "defaultParameter": false
                },
                {
                    "id": "customColor",
                    "name": "Выбор цвета",
                    "description": "Цвет иконки (работает только при включенном статическом цвете)",
